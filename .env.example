# ── LLM Provider ────────────────────────────────────────────────────────────────
# Option A: OpenAI (default)
OPENAI_API_KEY=sk-...

# Option B: Local LLM via OpenAI-compatible API
# LM Studio:  LLM_BASE_URL=http://localhost:1234/v1
# Ollama:     LLM_BASE_URL=http://localhost:11434/v1
# Then set model names to whatever your local model is called:
# EXTRACTION_MODEL=llama3
# QUERY_MODEL=llama3

# ── Model selection ──────────────────────────────────────────────────────────────
EXTRACTION_MODEL=gpt-4o-mini
QUERY_MODEL=gpt-4o

# ── Data directories ─────────────────────────────────────────────────────────────
RAW_DIR=./raw
GRAPHS_DIR=./graphs

# ── Pipeline parameters ──────────────────────────────────────────────────────────
MAX_PATHS_PER_CHUNK=20
NUM_WORKERS=4
MAX_CLUSTER_SIZE=10
MAX_DOCUMENTS=50
